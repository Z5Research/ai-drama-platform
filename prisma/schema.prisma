generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  password     String
  name         String?
  avatar       String?
  role         String      @default("user")
  status       String      @default("active")
  credits      Int         @default(0)
  totalCredits Int         @default(0)
  vipLevel     Int         @default(0)
  vipExpiredAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lastLoginAt  DateTime?
  apiKeys      ApiKey[]
  characters   Character[]
  creditLogs   CreditLog[]
  favorites    Favorite[]
  payments     Payment[]
  projects     Project[]
  scripts      Script[]
  templates    Template[]

  @@index([email])
  @@index([role])
}

model CreditLog {
  id          String    @id @default(cuid())
  userId      String
  amount      Int
  balance     Int
  type        String
  source      String?
  sourceId    String?
  description String?
  packageType String?
  expiredAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([type])
}

model CreditPackage {
  id        String   @id @default(cuid())
  name      String
  credits   Int
  price     Float
  bonus     Int      @default(0)
  validity  Int
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Payment {
  id            String    @id @default(cuid())
  userId        String
  orderNo       String    @unique
  amount        Float
  currency      String    @default("CNY")
  status        String    @default("pending")
  paymentMethod String
  transactionId String?
  prepaidId     String?
  packageId     String?
  packageType   String?
  creditsAmount Int?
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([orderNo])
}

model Project {
  id            String           @id @default(cuid())
  userId        String
  title         String
  description   String?
  coverImage    String?
  status        String           @default("draft")
  visibility    String           @default("private")
  workflowStage String           @default("script")
  videoRatio    String           @default("9:16")
  aiModel       String           @default("gpt-4")
  viewCount     Int              @default(0)
  likeCount     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  characters    Character[]
  episodes      Episode[]
  images        GeneratedImage[]
  videos        GeneratedVideo[]
  user          User             @relation(fields: [userId], references: [id])
  scripts       Script[]
  voicePresets  VoicePreset[]

  @@index([userId, status])
  @@index([visibility])
  @@index([workflowStage])
}

model Episode {
  id            String              @id @default(cuid())
  projectId     String
  episodeNumber Int
  title         String?
  description   String?
  novelText     String?
  audioUrl      String?
  srtContent    String?
  speakerVoices String?
  status        String              @default("draft")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  clips         Clip[]
  project       Project             @relation(fields: [projectId], references: [id])
  storyboards   Storyboard[]
  editorProject VideoEditorProject?
  voiceLines    VoiceLine[]

  @@unique([projectId, episodeNumber])
  @@index([projectId])
  @@index([status])
}

model VideoEditorProject {
  id           String   @id @default(cuid())
  episodeId    String   @unique
  projectData  String
  renderStatus String?
  renderTaskId String?
  outputUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  episode      Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([renderStatus])
}

model Clip {
  id         String      @id @default(cuid())
  episodeId  String
  clipNumber Int
  content    String
  summary    String?
  screenplay String?
  startTime  Float?
  endTime    Float?
  duration   Float?
  location   String?
  characters String?
  props      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  episode    Episode     @relation(fields: [episodeId], references: [id])
  storyboard Storyboard?

  @@unique([episodeId, clipNumber])
  @@index([episodeId])
}

model Storyboard {
  id              String   @id @default(cuid())
  episodeId       String
  clipId          String   @unique
  panelCount      Int      @default(9)
  previewUrl      String?
  photographyPlan String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  panels          Panel[]
  clip            Clip     @relation(fields: [clipId], references: [id])
  episode         Episode  @relation(fields: [episodeId], references: [id])

  @@index([episodeId])
  @@index([clipId])
}

model Panel {
  id                   String     @id @default(cuid())
  storyboardId         String
  panelIndex           Int
  panelNumber          Int?
  shotType             String?
  cameraMove           String?
  description          String?
  location             String?
  characters           String?
  props                String?
  srtSegment           String?
  srtStart             Float?
  srtEnd               Float?
  duration             Float?
  imagePrompt          String?
  imageUrl             String?
  imageStatus          String     @default("pending")
  candidateUrls        String?
  videoPrompt          String?
  videoUrl             String?
  videoStatus          String     @default("pending")
  firstLastFramePrompt String?
  videoGenerationMode  String?
  lipSyncTaskId        String?
  lipSyncVideoUrl      String?
  lipSyncStatus        String?
  notes                String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  storyboard           Storyboard @relation(fields: [storyboardId], references: [id])

  @@unique([storyboardId, panelIndex])
  @@index([storyboardId])
  @@index([imageStatus])
  @@index([videoStatus])
}

model VoiceLine {
  id                String   @id @default(cuid())
  episodeId         String
  lineIndex         Int
  speaker           String
  content           String
  voicePresetId     String?
  voiceId           String?
  voiceType         String?
  emotionPrompt     String?
  emotionStrength   Float?   @default(0.4)
  audioUrl          String?
  audioDuration     Int?
  matchedPanelId    String?
  matchedPanelIndex Int?
  srtStart          Float?
  srtEnd            Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  episode           Episode  @relation(fields: [episodeId], references: [id])

  @@unique([episodeId, lineIndex])
  @@index([episodeId])
  @@index([matchedPanelId])
  @@index([speaker])
}

model VoicePreset {
  id             String   @id @default(cuid())
  projectId      String
  name           String
  description    String?
  voiceId        String?
  voiceType      String?
  customVoiceUrl String?
  gender         String?
  style          String?
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([isSystem])
}

model Script {
  id             String   @id @default(cuid())
  projectId      String
  userId         String
  title          String
  content        String
  genre          String?
  style          String?
  isAiGenerated  Boolean  @default(false)
  aiModel        String?
  prompt         String?
  creditsCost    Int      @default(0)
  version        Int      @default(1)
  parentScriptId String?
  isShared       Boolean  @default(false)
  shareCode      String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
  project        Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@index([shareCode])
}

model Character {
  id                      String                @id @default(cuid())
  projectId               String?
  userId                  String
  name                    String
  description             String?
  aliases                 String?
  profileData             String?
  traits                  String?
  introduction            String?
  voiceId                 String?
  voiceType               String?
  customVoiceUrl          String?
  isGlobal                Boolean               @default(false)
  sourceGlobalCharacterId String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  user                    User                  @relation(fields: [userId], references: [id])
  project                 Project?              @relation(fields: [projectId], references: [id])
  appearances             CharacterAppearance[]

  @@index([projectId])
  @@index([userId, isGlobal])
  @@index([sourceGlobalCharacterId])
}

model CharacterAppearance {
  id                   String    @id @default(cuid())
  characterId          String
  appearanceIndex      Int       @default(0)
  changeReason         String    @default("初始形象")
  description          String?
  descriptions         String?
  imageUrl             String?
  imageUrls            String?
  selectedIndex        Int       @default(0)
  previousImageUrl     String?
  previousImageUrls    String?
  previousDescription  String?
  previousDescriptions String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  character            Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, appearanceIndex])
  @@index([characterId])
}

model GeneratedImage {
  id             String   @id @default(cuid())
  projectId      String
  prompt         String
  negativePrompt String?
  url            String
  thumbnailUrl   String?
  width          Int?
  height         Int?
  aiModel        String   @default("dall-e-3")
  creditsCost    Int      @default(0)
  status         String   @default("completed")
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model GeneratedVideo {
  id           String   @id @default(cuid())
  projectId    String
  prompt       String
  url          String
  thumbnailUrl String?
  duration     Float?
  aiModel      String   @default("sora")
  creditsCost  Int      @default(0)
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([status])
}

model Template {
  id          String     @id @default(cuid())
  creatorId   String
  name        String
  description String?
  category    String
  tags        String?
  content     String
  thumbnail   String?
  isFree      Boolean    @default(true)
  price       Int        @default(0)
  creditsCost Int        @default(0)
  useCount    Int        @default(0)
  likeCount   Int        @default(0)
  status      String     @default("active")
  isFeatured  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  favorites   Favorite[]
  creator     User       @relation(fields: [creatorId], references: [id])

  @@index([category, status])
  @@index([creatorId])
  @@index([isFeatured])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  createdAt  DateTime @default(now())
  template   Template @relation(fields: [templateId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, templateId])
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  key         String    @unique
  prefix      String
  permissions String?
  rateLimit   Int       @default(100)
  lastUsedAt  DateTime?
  usageCount  Int       @default(0)
  expiresAt   DateTime?
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([key])
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model AiUsageLog {
  id           String   @id @default(cuid())
  userId       String
  model        String
  type         String
  inputTokens  Int?
  outputTokens Int?
  totalTokens  Int?
  creditsCost  Int
  projectId    String?
  requestId    String?
  latency      Int?
  status       String
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([model, type])
}
